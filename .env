# =============================================================================
# Docker Compose — Environment Variables
# Salin ke .env di root project: cp .env.docker.example .env
# =============================================================================

# ─── Port mapping (host) ─────────────────────────────────────────────────────
APP_PORT=8000
MYSQL_PORT=3306
NGROK_UI_PORT=4040

# ─── MySQL ───────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=secret_root_password
MYSQL_DATABASE=script_lisensi
MYSQL_USER=script_lisensi
MYSQL_PASSWORD=secret_db_password

# ─── Laravel Backend ─────────────────────────────────────────────────────────
APP_ENV=local
APP_DEBUG=true
# Token rahasia untuk komunikasi Bot <-> Laravel (harus sama di kedua .env)
DISCORD_BOT_API_TOKEN=612b57681e96f8d4b68bf526c6f6aacfbd83d939fcf17e511ec2927c743458dc

# ─── ngrok (wajib untuk start.sh local tunnel) ───────────────────────────────
# Dapatkan token gratis di: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=2luxiZoFwHec1pdMWHdAPtIQAGe_6LNPRrZM2DrkqD2naDNto
# Static custom domain ngrok — URL tidak berubah saat restart
NGROK_URL=unfertile-proconsularly-dorris.ngrok-free.dev

# ─── Build target ─────────────────────────────────────────────────────────────
# production | development
BACKEND_BUILD_TARGET=development

# ─── Startup behaviour ───────────────────────────────────────────────────────
RUN_MIGRATIONS=false
WAIT_FOR_DB=true
WAIT_FOR_LARAVEL=true
