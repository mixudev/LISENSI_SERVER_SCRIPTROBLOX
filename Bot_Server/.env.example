# =======================================
# DISCORD BOT CONFIGURATION
# =======================================
DISCORD_TOKEN=ISI_DENGAN_TOKEN_BOT_DISCORD_ANDA
CLIENT_ID=ISI_DENGAN_APPLICATION_CLIENT_ID

# ID Channel khusus tempat Dashboard GUI (pesan persistent) akan ditampilkan
DASHBOARD_CHANNEL_ID=ISI_DENGAN_ID_CHANNEL

# ID Role yang diizinkan menggunakan tombol "Generate Key" (Admin/Reseller)
ADMIN_ROLE_ID=ISI_DENGAN_ID_ROLE_ADMIN

# =======================================
# LARAVEL BACKEND (Bot API — /api/bot/*)
# =======================================
# URL Backend Laravel (sama host dengan APP_URL), contoh: http://127.0.0.1:8000 atau https://xxxx.ngrok-free.app
LARAVEL_API_URL=http://127.0.0.1:8000

# HARUS SAMA dengan DISCORD_BOT_API_TOKEN di Backend/.env
LARAVEL_API_TOKEN=ISI_TOKEN_RAHASIA_YANG_SAMA_DENGAN_BACKEND

# Timeout request ke Laravel API (dalam milidetik)
LARAVEL_API_TIMEOUT=8000
